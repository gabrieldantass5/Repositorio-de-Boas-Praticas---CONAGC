# Repositório de Boas Práticas - CONAGC
# Arquivo de exemplo de variáveis de ambiente

# API Configuration (quando implementado)
# VITE_API_URL=http://localhost:3000/api
# VITE_API_KEY=your_api_key_here

# Google Gemini API (se necessário)
# GEMINI_API_KEY=your_gemini_api_key_here

# Environment
# NODE_ENV=development

# Feature Flags (futuro)
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_COMMENTS=false
# VITE_ENABLE_NOTIFICATIONS=false

# Database (quando implementado)
# DATABASE_URL=postgresql://user:password@localhost:5432/conagc_db

# Authentication (quando implementado)
# VITE_AUTH_DOMAIN=your-auth-domain.com
# VITE_AUTH_CLIENT_ID=your_client_id

# Storage (quando implementado)
# VITE_STORAGE_BUCKET=conagc-practices
# VITE_STORAGE_REGION=us-east-1

# Instruções:
# 1. Copie este arquivo para .env.local
# 2. Preencha as variáveis necessárias
# 3. Nunca commite o arquivo .env.local (já está no .gitignore)
